# .dockerignore — bc-sql Bootcamp
# Excluye del build context archivos innecesarios para la imagen PostgreSQL.
# El build context es scripts/ (context: . en docker-compose.yml).

# Control de versiones
.git/
.gitignore
.gitmessage

# Editor y configuración de IDE
.vscode/
.github/

# Documentación y assets del proyecto
README.md
README_EN.md
LICENSE
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
docs/
assets/

# Contenido del bootcamp (los .sql se pasan por stdin o se montan en runtime)
bootcamp/

# Archivos de entorno y secretos
.env
.env.*
*.env

# Scripts de pausa/restauración (no van dentro del contenedor)
scripts/pause.sh
scripts/resume.sh
scripts/restore.sh

# Archivos de sistema y temporales
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*.swo
